# Barra Vips local/dev environment

# Database
# Supabase Session Pooler. Use this on IPv4-only networks.
DATABASE_URL=postgresql://postgres.zinrqzsxvpqfoogohrwg:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
# Supabase Transaction Pooler alternative:
# DATABASE_URL=postgresql://postgres.zinrqzsxvpqfoogohrwg:YOUR_PASSWORD@aws-1-us-east-1.pooler.supabase.com:6543/postgres?sslmode=require
# Supabase direct connection. Requires IPv6 support on the client network:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.zinrqzsxvpqfoogohrwg.supabase.co:5432/postgres?sslmode=require

# Operational API
OPERATOR_API_KEY=dev-operator-api-key
CORS_ORIGINS=http://localhost:3000

# Evolution API
EVOLUTION_INSTANCE=barra-vips-main
EVOLUTION_API_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_WEBHOOK_SECRET=dev-evolution-webhook-secret
# CSV de remoteJids permitidos. Vazio = sem filtro. Para limitar a um unico grupo
# coloque o JID do grupo (ex.: 1203630xxxxxxxxxx@g.us). 1-a-1 usa @s.whatsapp.net.
EVOLUTION_ALLOWED_REMOTE_JIDS=

# Chatwoot
CHATWOOT_WEBHOOK_SECRET=dev-chatwoot-webhook-secret

# Calendar
CALENDAR_INSTANCE=default
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# LLM and transcription
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# Observability
LANGFUSE_HOST=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# Handoff and UI
HANDOFF_NOTIFICATION_GROUP_JID=
OPERATOR_UI_BASE_URL=

# Media
MEDIA_STORAGE_DIR=storage/media
# 0 means no application-level limit. Use reverse proxy/container limits before production.
MAX_MEDIA_UPLOAD_BYTES=0
ALLOWED_MEDIA_TYPES=image,video
